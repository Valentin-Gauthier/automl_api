<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".AddVehicleActivity">

    <!-- Header fixe -->
    <include layout="@layout/header" />

    <!-- Form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Group vehicle identity -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_identity"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/vehicleBrand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="brand"
                android:hint="@string/vehicle_brand"
                android:importantForAutofill="yes"
                android:inputType="text"
                android:minHeight="48dp" />

            <EditText
                android:id="@+id/vehicleModel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="model"
                android:hint="@string/vehicle_model"
                android:importantForAutofill="yes"
                android:inputType="text"
                android:minHeight="48dp" />

            <EditText
                android:id="@+id/vehicleDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="date"
                android:hint="@string/vehicle_date"
                android:importantForAutofill="yes"
                android:inputType="date"
                android:minHeight="48dp" />

            <EditText
                android:id="@+id/vehicleColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="color"
                android:hint="@string/vehicle_color"
                android:importantForAutofill="yes"
                android:inputType="text"
                android:minHeight="48dp" />

            <!-- Group Motorisation -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_motorization"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/vehicleEnergyType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="energyType"
                android:hint="@string/vehicle_energy_type"
                android:importantForAutofill="yes"
                android:minHeight="48dp"
                android:spinnerMode="dropdown" />

            <Spinner
                android:id="@+id/vehicleGearboxType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="gearboxType"
                android:hint="@string/vehicle_gearbox_type"
                android:importantForAutofill="yes"
                android:minHeight="48dp"
                android:spinnerMode="dropdown" />

            <EditText
                android:id="@+id/vehicleGearboxSpeed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="gearboxSpeed"
                android:hint="@string/vehicle_gearbox_speed"
                android:importantForAutofill="yes"
                android:inputType="number"
                android:minHeight="48dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ui_important_information_note"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <!-- Group Kilométrage -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_mileage"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <!-- Custom Slider (route + voiture) -->
            <SeekBar
                android:id="@+id/mileageSlider"
                android:layout_width="match_parent"
                android:layout_height="@android:dimen/app_icon_size"
                android:background="@drawable/road_slider"
                android:thumb="@drawable/car_slider"
                android:hint="@string/ui_mileage_slider_thumb"
                android:importantForAutofill="yes"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_average_mileage_france"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="16dp"/>

            <!-- Bouton de validation -->
            <Button
                android:id="@+id/btnEstimatePrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/action_estimate_price"
                android:textAllCaps="false"
                android:layout_marginTop="16dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- Footer fixe -->
    <include layout="@layout/footer" />
</LinearLayout>