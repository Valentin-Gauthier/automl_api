<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Header fixe -->
    <include layout="@layout/header" />

    <!-- Form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Group vehicle identity -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_identity"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="4dp"/>

            <EditText
                android:id="@+id/vehicleBrand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="brand"
                android:hint="@string/vehicle_brand"
                android:importantForAutofill="yes"
                android:inputType="text"
                android:minHeight="48dp" />

            <EditText
                android:id="@+id/vehicleModel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="model"
                android:hint="@string/vehicle_model"
                android:importantForAutofill="yes"
                android:inputType="text"
                android:minHeight="48dp" />

            <EditText
                android:id="@+id/vehicleVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="version"
                android:hint="@string/vehicle_version"
                android:importantForAutofill="yes"
                android:inputType="text"
                android:minHeight="48dp" />

            <!-- Date : bouton système -->
            <EditText
                android:id="@+id/vehicleDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:autofillHints="date"
                android:hint="@string/vehicle_date_picker_btn"
                android:importantForAutofill="yes"
                android:inputType="date"
                android:minHeight="48dp"
                android:textSize="15sp"/>

            <EditText
                android:id="@+id/vehicleColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="color"
                android:hint="@string/vehicle_color"
                android:importantForAutofill="yes"
                android:inputType="text"
                android:minHeight="48dp" />

            <EditText
                android:id="@+id/vehicleVin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="vin"
                android:hint="@string/vehicle_vin"
                android:importantForAutofill="yes"
                android:inputType="text"
                android:minHeight="48dp" />

            <EditText
                android:id="@+id/vehicleCountry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="countryCode"
                android:hint="@string/vehicle_country"
                android:importantForAutofill="yes"
                android:inputType="text"
                android:minHeight="48dp" />

            <!-- Group Motorisation -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_motorization"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_energy_type"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="2dp"/>
            <Spinner
                android:id="@+id/vehicleEnergyType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:spinnerMode="dropdown" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_gearbox_type"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="2dp"/>
            <Spinner
                android:id="@+id/vehicleGearboxType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:spinnerMode="dropdown" />

            <EditText
                android:id="@+id/vehicleGearboxSpeed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="gearboxSpeed"
                android:hint="@string/vehicle_gearbox_speed"
                android:importantForAutofill="yes"
                android:inputType="number"
                android:minHeight="48dp" />

            <!-- Group power -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/vehiclePowerKw"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="powerKiloWatt"
                    android:hint="@string/vehicle_power_kw"
                    android:importantForAutofill="yes"
                    android:inputType="text"
                    android:minHeight="48dp" />

                <EditText
                    android:id="@+id/vehiclePowerHp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="powerHP"
                    android:hint="@string/vehicle_power_hp"
                    android:importantForAutofill="yes"
                    android:inputType="text"
                    android:minHeight="48dp" />
            </LinearLayout>

            <!-- Group carrosserie -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_body_section"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_body_type"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="2dp"/>
            <Spinner
                android:id="@+id/vehicleBodyType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:spinnerMode="dropdown" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_genre_type"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="2dp"/>
            <Spinner
                android:id="@+id/vehicleGenreType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:spinnerMode="dropdown" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/vehicleDoors"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="numberOfDoors"
                    android:hint="@string/vehicle_doors"
                    android:importantForAutofill="yes"
                    android:inputType="text"
                    android:minHeight="48dp" />

                <EditText
                    android:id="@+id/vehiclePassengers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="numberOfPassengers"
                    android:hint="@string/vehicle_passengers"
                    android:importantForAutofill="yes"
                    android:inputType="text"
                    android:minHeight="48dp" />
            </LinearLayout>

            <!-- Group poids ET puissance -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_weight_section"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="4dp"/>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/vehicleWeightKg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="weightKg"
                    android:hint="@string/vehicle_weight_kg"
                    android:importantForAutofill="yes"
                    android:inputType="number"
                    android:minHeight="48dp" />

                <EditText
                    android:id="@+id/vehicleGrossWeightKg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="grossWeightKg"
                    android:hint="@string/vehicle_gross_weight_kg"
                    android:importantForAutofill="yes"
                    android:inputType="number"
                    android:minHeight="48dp" />
            </LinearLayout>

            <EditText
                android:id="@+id/vehicleFuelTank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="fuelTank"
                android:hint="@string/vehicle_fuel_tank"
                android:importantForAutofill="yes"
                android:inputType="text"
                android:minHeight="48dp" />

            <!-- Group Kilométrage -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_mileage"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <!-- Custom Slider (route + voiture) -->
            <SeekBar
                android:id="@+id/mileageSlider"
                android:layout_width="match_parent"
                android:layout_height="@android:dimen/app_icon_size"
                android:background="@drawable/road_slider"
                android:thumb="@drawable/car_slider"
                android:hint="@string/ui_mileage_slider_thumb"
                android:importantForAutofill="yes"/>
            <!-- Valeur du kilométrage au-dessus du slider -->
            <TextView
                android:id="@+id/mileageValueText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_average_mileage_france"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="16dp"/>

            <!-- Bouton de validation -->
            <Button
                android:id="@+id/btnEstimatePrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/action_estimate_price"
                android:textAllCaps="false"
                android:layout_marginTop="16dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- Footer fixe -->
    <include layout="@layout/footer" />
</LinearLayout>