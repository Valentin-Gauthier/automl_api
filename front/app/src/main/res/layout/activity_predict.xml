<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Header -->
    <include layout="@layout/header" />

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Group 1: Result -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/price_estimation_title"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginBottom="16dp"/>

            <!-- Table for price estimation -->
            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="1">
                <TableRow>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_used_vehicle"
                        android:textColor="?android:attr/textColorSecondary"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_range_start"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:id="@+id/usedPriceMin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_example"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_currency_unit"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_range_middle"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:id="@+id/usedPriceMax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_example"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_currency_unit"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_range_end"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                </TableRow>

                <TableRow>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_new_vehicle"
                        android:textColor="?android:attr/textColorSecondary"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_range_start"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:id="@+id/newPriceMin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_example"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_currency_unit"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_range_middle"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:id="@+id/newPriceMax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_example"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_currency_unit"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_range_end"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                </TableRow>
            </TableLayout>

            <!-- Group 2: Action -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:gravity="center">

                <Button
                    android:id="@+id/btnFindNearestGarage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/action_search_nearby_garage"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnPrepareAd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/action_prepare_ad"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnAddToList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/action_save_to_list"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Footer -->
    <include layout="@layout/footer" />
</LinearLayout>