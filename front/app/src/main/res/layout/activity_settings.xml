<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include layout="@layout/header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ════════════════════════════════════════════
                 SECTION : GALERIE
                 ════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Titre de section -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="@string/settings_gallery_section"
                        android:textAlignment="center"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Taille de la galerie -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/settings_gallery_size_label"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/gallerySizeLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginBottom="4dp"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <SeekBar
                        android:id="@+id/gallerySizeSeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp" />

                    <!-- Onglets automatiques -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/settings_gallery_tabs_label"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="14sp" />

                    <!-- Onglet "Tout afficher" -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ToggleButton
                            android:id="@+id/ShowAll"
                            android:layout_width="84dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="8dp" />

                        <EditText
                            android:id="@+id/ShowAllName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:importantForAutofill="no"
                            android:inputType="text"
                            tools:ignore="LabelFor,SpeakableTextPresentCheck,TouchTargetSizeCheck,VisualLintTextFieldSize" />

                    </LinearLayout>

                    <!-- Onglet "Non catégorisé" -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ToggleButton
                            android:id="@+id/ShowNotCategorized"
                            android:layout_width="84dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="8dp" />

                        <EditText
                            android:id="@+id/ShowNotCategorizedName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:importantForAutofill="no"
                            android:inputType="text"
                            tools:ignore="LabelFor,SpeakableTextPresentCheck,TouchTargetSizeCheck,VisualLintTextFieldSize" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════════════
                 SECTION : API
                 ════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Titre de section -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="@string/settings_apis_section"
                        android:textAlignment="center"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Sous-titre API -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/settings_api_section"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/settings_api_token_label"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/apiTokenInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:autofillHints="mytoken"
                        android:hint="@string/settings_api_token_hint"
                        android:inputType="textPassword"
                        tools:ignore="TouchTargetSizeCheck,VisualLintTextFieldSize" />

                    <Button
                        android:id="@+id/btnClearToken"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_clear_token"
                        android:textAllCaps="false" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════════════
                 BOUTON SAUVEGARDER
                 ════════════════════════════════════════════ -->
            <Button
                android:id="@+id/btnSaveSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_save"
                android:textAllCaps="false"
                tools:ignore="VisualLintButtonSize" />

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/footer" />
</LinearLayout>