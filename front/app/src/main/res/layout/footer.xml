<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorPrimarySurface"
    android:gravity="center"
    android:orientation="horizontal"
    android:padding="12dp">

    <Space
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.25" />

    <Button
        android:id="@+id/FooterBtnHome"
        android:layout_width="0dp"
        android:layout_height="@android:dimen/app_icon_size"
        android:layout_weight="1"
        android:drawableTop="@drawable/ic_home"
        android:scaleType="centerInside"
        android:text="@string/footerBtnHome" />

    <Space
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.25" />

    <Button
        android:id="@+id/FooterBtnAddVehicle"
        android:layout_width="0dp"
        android:layout_height="@android:dimen/app_icon_size"
        android:layout_weight="1"
        android:drawableTop="@drawable/ic_add_vehicle"
        android:scaleType="centerInside"
        android:text="@string/footerBtnAddvehicle" />

    <Space
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.25" />

    <Button
        android:id="@+id/FooterBtnConfig"
        android:layout_width="0dp"
        android:layout_height="@android:dimen/app_icon_size"
        android:layout_weight="1"
        android:drawableTop="@android:drawable/ic_menu_set_as"
        android:scaleType="centerInside"
        android:text="@string/footerBtnConfig" />

    <Space
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.25" />
</LinearLayout>