<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Header fixe -->
    <include layout="@layout/header" />

    <!-- Form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Group vehicle identity -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_identity"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/vehicleBrand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:hint="@string/brand"
                android:importantForAutofill="yes"
                android:autofillHints="brand"/>

            <EditText
                android:id="@+id/vehicleModel"
                android:hint="@string/model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:importantForAutofill="yes"
                android:autofillHints="model"/>

            <EditText
                android:id="@+id/vehicleDate"
                android:hint="@string/date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:focusable="false"
                android:importantForAutofill="yes"
                android:autofillHints="date"/>

            <EditText
                android:id="@+id/vehicleColor"
                android:hint="@string/color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:importantForAutofill="yes"
                android:autofillHints="color"/>

            <!-- Group Motorisation -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/motorisation"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/vehicleEnergyType"
                android:hint="@string/energy_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:importantForAutofill="yes"
                android:autofillHints="energyType"
                android:spinnerMode="dropdown" />

            <Spinner
                android:id="@+id/vehicleGearboxType"
                android:hint="@string/gearbox_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:importantForAutofill="yes"
                android:autofillHints="gearboxType"
                android:spinnerMode="dropdown" />

            <EditText
                android:id="@+id/vehicleGearboxSpeed"
                android:hint="@string/gearbox_speed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:importantForAutofill="yes"
                android:autofillHints="gearboxSpeed"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/important_information"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <!-- Group Kilométrage -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mileage"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <!-- Custom Slider (route + voiture) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@android:dimen/app_icon_size"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="@android:dimen/app_icon_size"
                    android:src="@drawable/roadslider"
                    android:scaleType="fitXY"
                    android:adjustViewBounds="true"/>
                <ImageView
                    android:id="@+id/mileageSliderThumb"
                    android:layout_width="@android:dimen/app_icon_size"
                    android:layout_height="@android:dimen/app_icon_size"
                    android:src="@drawable/carslider"
                    android:layout_gravity="center"
                    android:contentDescription="@string/slider_thumb"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/average_mileage_france"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="16dp"/>

            <!-- Bouton de validation -->
            <Button
                android:id="@+id/btnEstimatePrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/estimate_price"
                android:textAllCaps="false"
                style="?android:attr/borderlessButtonStyle"
                android:layout_marginTop="16dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- Footer fixe -->
    <include layout="@layout/footer" />
</LinearLayout>