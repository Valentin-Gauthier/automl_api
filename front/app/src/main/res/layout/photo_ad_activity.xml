<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Visionneur de la caméra -->
    <TextureView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"/>

    <!-- Flou des bords -->
    <View
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="top"
        android:background="#80000000"/>
    <View
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="bottom"
        android:background="#80000000"/>
    <View
        android:layout_width="100dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#80000000"/>
    <View
        android:layout_width="100dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#80000000"/>

    <!-- Consigne (visible uniquement en mode paysage) -->
    <TextView
        android:id="@+id/tvInstruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="16dp"
        android:text="@string/photo_consign"
        android:textColor="?android:attr/textColorPrimaryInverse"
        android:textSize="14sp"
        tools:visibility="visible"/>

    <!-- Guides d'alignement -->
    <!-- Guide vertical (niveau de rotation) -->
    <SeekBar
        android:id="@+id/rotateAlignmentGuide"
        android:layout_width="33dp"
        android:layout_height="match_parent"
        android:clickable="false"
        android:max="100"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="33dp"
        android:background="?android:attr/colorPrimary"
        android:thumb="@drawable/carslider"
        android:alpha="0.7"/>

    <!-- Guide horizontal (niveau de tangage) -->
    <SeekBar
        android:id="@+id/tanguageAlignmentGuide"
        android:layout_width="match_parent"
        android:layout_height="33dp"
        android:clickable="false"
        android:max="100"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="33dp"
        android:background="?android:attr/colorPrimary"
        android:thumb="@drawable/carslider"
        android:alpha="0.7"/>

    <!-- Bouton de déclenchement -->
    <ImageButton
        android:id="@+id/btnTriggerScan"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="18dp"
        android:background="@drawable/circle_header_background"
        android:src="@android:drawable/ic_menu_camera"
        android:contentDescription="@string/photo_trigger"/>
</FrameLayout>