<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <!-- Header -->
    <include layout="@layout/header" />

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Group 1: Result -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/estimation_prix"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginBottom="16dp"/>

            <!-- Table for price estimation -->
            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="1">
                <TableRow>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/prix_occasion"
                        android:textColor="?android:attr/textColorSecondary"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_start"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:id="@+id/usedPriceMin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/exemple_price"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_unit"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_middle"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:id="@+id/usedPriceMax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/exemple_price"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_unit"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_end"
                        android:textColor="?android:attr/textColorPrimary"
                        android:padding="8dp"/>
                </TableRow>

            <TableRow>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/prix_neuf"
                    android:textColor="?android:attr/textColorSecondary"
                    android:padding="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/price_start"
                    android:textColor="?android:attr/textColorPrimary"
                    android:padding="8dp"/>
                <TextView
                    android:id="@+id/newPriceMin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/exemple_price"
                    android:textColor="?android:attr/textColorPrimary"
                    android:padding="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/price_unit"
                    android:textColor="?android:attr/textColorPrimary"
                    android:padding="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/price_middle"
                    android:textColor="?android:attr/textColorPrimary"
                    android:padding="8dp"/>
                <TextView
                    android:id="@+id/newPriceMax"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/exemple_price"
                    android:textColor="?android:attr/textColorPrimary"
                    android:padding="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/price_unit"
                    android:textColor="?android:attr/textColorPrimary"
                    android:padding="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/price_end"
                    android:textColor="?android:attr/textColorPrimary"
                    android:padding="8dp"/>
            </TableRow>
        </TableLayout>

        <!-- Group 2: Action -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:gravity="center">

            <Button
                android:id="@+id/btnFindNearestGarage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/search_car"
                android:layout_marginBottom="8dp"
                style="?android:attr/borderlessButtonStyle"/>

            <Button
                android:id="@+id/btnPrepareAd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/create_ad"
                android:layout_marginBottom="8dp"
                style="?android:attr/borderlessButtonStyle"/>

            <Button
                android:id="@+id/btnAddToList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/save"
                style="?android:attr/borderlessButtonStyle"/>
        </LinearLayout>
    </LinearLayout>
    </ScrollView>

    <!-- Footer -->
    <include layout="@layout/footer" />
</LinearLayout>