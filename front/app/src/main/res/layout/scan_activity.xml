<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include layout="@layout/photo" />

    <!-- Consigne (visible uniquement en mode paysage) -->
    <TextView
        android:id="@+id/tvInstruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="16dp"
        android:text="@string/instruction_scan_consign"
        android:textColor="?android:attr/textColorPrimaryInverse"
        android:textSize="14sp"/>

    <!-- Marque d'alignement bleue à gauche -->
    <View
        android:id="@+id/leftBlueMark"
        android:layout_width="32dp"
        android:layout_height="128dp"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="64dp"
        android:background="#4285F4"/>

    <!-- Marque d'alignement bleue à droite -->
    <View
        android:id="@+id/rightBlueMark"
        android:layout_width="32dp"
        android:layout_height="128dp"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="64dp"
        android:background="#4285F4"/>

    <!-- Bouton de déclenchement -->
    <ImageButton
        android:id="@+id/btnTriggerScan"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="18dp"
        android:background="@drawable/circle_header_background"
        android:src="@android:drawable/ic_menu_camera"
        android:contentDescription="@string/action_scan_trigger"/>
</FrameLayout>